# =============================================================================
# ARAKAWA Business System — 環境変数テンプレート
# コピー例: cp .env.example .env  （ルートに .env を置く）
# Supabase: Dashboard → Project Settings → Database → Connection string
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL（Supabase 推奨）
# -----------------------------------------------------------------------------
# URI 形式。Supabase では「Connection pooling」用（Transaction / Session）と
# 「Direct connection」を選べます。サーバーレス・長時間APIはプーラー利用を検討。
#
# 例（プレースホルダ）:
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# または Direct:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
#
DATABASE_URL=

# -----------------------------------------------------------------------------
# バックエンド API（Express）
# -----------------------------------------------------------------------------
# 本番では十分に長いランダム文字列を設定すること
JWT_SECRET=

# ホストが PORT を渡す場合は未設定でよい（既定 4000）
# PORT=4000

# 任意
# PG_CONNECTION_TIMEOUT_MS=8000
# HEALTH_DB_TIMEOUT_MS=5000
# MASK_API_ERRORS=1

# -----------------------------------------------------------------------------
# フロント（Next.js）— ローカル開発用 .env.local にも同様に記載可
# -----------------------------------------------------------------------------
# サーバー側プロキシ（app/api/[[...path]]）が転送するバックエンドのオリジン。
# 末尾に /api は付けない（パスは /api/... のまま転送される）
BACKEND_PROXY_TARGET=http://127.0.0.1:4000

# SSR 等で apiBaseUrl() が参照。本番（Vercel）は Render 等の API を必ず https:// で（http だとブラウザがブロック）
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
