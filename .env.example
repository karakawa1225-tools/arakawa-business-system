# =============================================================================
# ARAKAWA Business System — 環境変数テンプレート
# コピー例: cp .env.example .env  （ルートに .env を置く）
# Supabase: Dashboard → Project Settings → Database → Connection string
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL（Supabase 推奨）
# -----------------------------------------------------------------------------
# URI 形式。Supabase では「Connection pooling」用（Transaction / Session）と
# 「Direct connection」を選べます。手入力でホストやポートを混ぜると接続できません。
#
# 推奨: Dashboard → Project Settings → Database → Connection string で
# 「URI」を選び、そのままコピー（ホスト名はプロジェクトごとに異なります）。
#
# Transaction pooler（例・プレースホルダ。実際のホストは画面の値を使う）:
#   ユーザー: postgres.[project_ref]
#   ホスト: *.pooler.supabase.com
#   ポート: 6543
#   例:
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Direct connection（マイグレーションや長時間セッション向け）:
#   ユーザー: postgres（.[ref] は付けない）
#   ホスト: db.[ref].supabase.co
#   ポート: 5432
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
#
# エラー「tenant/user postgres.xxx not found」が出るとき:
#   pooler 用ユーザー名を direct 用ホストに付けていたり、ポート 5432/6543 と
#   モードの組み合わせが画面と違っていることが多いです。上記いずれかに揃え直す。
#
DATABASE_URL=

# -----------------------------------------------------------------------------
# バックエンド API（Express）
# -----------------------------------------------------------------------------
# 本番では十分に長いランダム文字列を設定すること
JWT_SECRET=

# ホストが PORT を渡す場合は未設定でよい（既定 4000）
# PORT=4000

# 任意
# PG_CONNECTION_TIMEOUT_MS=8000
# HEALTH_DB_TIMEOUT_MS=5000
# MASK_API_ERRORS=1

# -----------------------------------------------------------------------------
# フロント（Next.js）— ローカル開発用 .env.local にも同様に記載可
# -----------------------------------------------------------------------------
# サーバー側プロキシ（app/api/[[...path]]）が転送するバックエンドのオリジン。
# 末尾に /api は付けない（パスは /api/... のまま転送される）
BACKEND_PROXY_TARGET=http://127.0.0.1:4000

# ブラウザが API に直叩きする場合のオリジン（末尾に /api は付けない）。
# ローカル: http://127.0.0.1:4000
# Vercel 本番: 必ず https://（例: https://arakawa-business-system.onrender.com）。
#   http:// だと HTTPS のページからミックスコンテンツでブロックされる。
#   未設定にするとブラウザは同一オリジンの /api のみ使う（Vercel の Route Handler 経由で Render へプロキシ）。
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
